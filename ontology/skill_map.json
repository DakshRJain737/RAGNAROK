{
  "_meta": {
    "version": "1.0.0",
    "description": "Skill ontology for the Redrob AI candidate ranking pipeline. Covers synonyms, co-occurring skills, domain-transfer mappings, and seniority adjacency for Senior AI Engineer matching.",
    "created_for": "Senior AI Engineer — Redrob AI (Series A, Pune/Noida)",
    "normalization": "All keys and values are lowercase, space-separated. Normalize candidate skill names to lowercase before lookup.",
    "key_domain_transfers": [
      "recommendation systems → information retrieval  [primary Tier-5 rescue path]",
      "recsys → ranking",
      "nlp → information retrieval",
      "search engineering → information retrieval",
      "applied machine learning → information retrieval"
    ],
    "schema": {
      "synonyms": "skill → [near-equivalent names]. Bidirectional: if A lists B, B lists A. Used by query_expander.py for BM25 expansion and candidate_parser.py for skill normalisation.",
      "co_skills": "skill → [skills that commonly appear together in AI/ML profiles]. Directional. Presence of key implies likely competence in values. Used by scoring/skill_match.py for partial credit.",
      "domain_transfers": "source domain → [JD target domains this domain maps into]. Used by graph_traversal.py for Tier-5 BFS rescue: a candidate with [key] skills is a plausible fit for [values] roles.",
      "seniority_adjacency": "role title → [adjacent roles that signal equivalent expertise level]. Used by jd_parser.py for career-history signal expansion."
    }
  },

